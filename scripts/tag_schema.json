  "params": [
    {
      "name": "speed",
      "display": "速度(Mbps)",
      "patterns": [
        "(\\d+\\.?\\d*)\\s*(G|g)\\s*bps",
        "(\\d+\\.?\\d*)\\s*(M|m)\\s*bps",
        "(\\d+\\.?\\d*)\\s*(k|K)\\s*bps"
      ],
      "thresholds": [
        200,
        150,
        100,
        50,
        20,
        10,
        5,
        2,
        1
      ],
      "unit": "Mbps",
      "guard": "not preceded by mV/mA/mHz"
    },
    {
      "name": "txr",
      "display": "收发数",
      "patterns": [
        "(\\d+)\\s*T\\s*(\\d+)\\s*R",
        "(\\d+)\\s*发\\s*(\\d+)\\s*收"
      ],
      "thresholds": []
    },
    {
      "name": "current",
      "display": "输出电流",
      "patterns": [
        "(\\d+\\.?\\d*)\\s*A\\b(?!\\w)",
        "(\\d+)\\s*mA\\b"
      ],
      "thresholds": [
        12,
        10,
        8,
        7,
        6,
        5,
        4,
        3,
        2,
        1,
        0.5
      ],
      "unit": "A",
      "tag_prefix": "Iout_"
    },
    {
      "name": "voltage",
      "display": "电压",
      "patterns": [
        "(\\d+\\.?\\d*)\\s*V\\b(?!\\w)"
      ],
      "thresholds": [
        48,
        36,
        24,
        12,
        5,
        3.3,
        2.5,
        1.8,
        1.2,
        1,
        0.8,
        0.6
      ],
      "unit": "V",
      "tag_prefix": "Vin_"
    },
    {
      "name": "channels",
      "display": "通道数",
      "patterns": [
        "(\\d+)\\s*通道",
        "(\\d+)\\s*路\\b"
      ],
      "thresholds": [
        32,
        16,
        8,
        4,
        2,
        1
      ],
      "unit": "通道"
    },
    {
      "name": "bits",
      "display": "分辨率",
      "patterns": [
        "(\\d+)\\s*bit\\b"
      ],
      "thresholds": [
        24,
        20,
        18,
        16,
        14,
        12,
        10,
        8
