  "tag_constraints": {
    "精密(≤1mV)": {
      "description": "Vos(Max)必须 ≤ 1.0mV",
      "param_pattern": "Vos\\s*\\(Max\\)\\s*\\(mV\\)\\s*[:：]\\s*([\\d.]+)",
      "validate": "float(value) <= 1.0",
      "fail_action": "remove_tag"
    },
    "轨到轨": {
      "description": "Rail-Rail In 必须为 Yes（仅输出轨到轨不算）",
      "param_pattern": "Rail-Rail\\s*In\\s*[:：]\\s*Yes",
      "validate": "match is not None",
      "fail_action": "remove_tag"
    },
    "高PSRR": {
      "description": "PSRR 需有 dB 值且 ≥ 60dB",
      "param_pattern": "PSRR.*?(\\d+)\\s*dB",
      "validate": "float(value) >= 60",
      "fail_action": "remove_tag"
    },
    "低功耗唤醒": {
      "description": "需有 wake/唤醒/standby/sleep 或 partial networking",
      "param_pattern": "(?:wake|唤醒|standby|sleep|partial.network)",
      "validate": "match is not None",
      "fail_action": "remove_tag"
    },
    "低噪声": {
      "description": "需有 noise/PSRR/噪声/Vn 参数",
      "param_pattern": "(?:noise|psrr|噪声|vn.at|peak.noise)",
      "validate": "match is not None",
      "fail_action": "remove_tag"
    }
  }
